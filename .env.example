# Anthropic
ANTHROPIC_API_KEY=sk-ant-你的key

# Supabase（后端用 service_role，绝不放进前端）
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...

# 访问密码
APP_PASSWORD=你自定义的密码

# Webhook 签名/密钥。留空则 webhook 放行。
WEBHOOK_SECRET=your-shared-secret-here

# 允许跨域的前端域名（逗号分隔）
ALLOWED_ORIGINS=https://你的项目.vercel.app,http://localhost:3000
